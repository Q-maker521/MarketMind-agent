# Runtime
MARKETMIND_APP_ENV=development
MARKETMIND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Market data provider.
# Use "mock" for stable public demos.
# Use "twelve_data" for demo-key real historical US market data.
# Use "alpha_vantage" only when MARKETMIND_ALPHA_VANTAGE_API_KEY is configured.
MARKETMIND_MARKET_DATA_PROVIDER=mock
MARKETMIND_ALPHA_VANTAGE_API_KEY=
MARKETMIND_TWELVE_DATA_API_KEY=demo

# LLM provider.
# Use "mock" for deterministic local report writing.
# Use "openai_compatible" for providers that expose /chat/completions.
MARKETMIND_LLM_PROVIDER=mock
MARKETMIND_LLM_API_BASE_URL=
MARKETMIND_LLM_API_KEY=
MARKETMIND_LLM_MODEL=
